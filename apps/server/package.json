{
  "name": "@blindpass/server",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src",
    "test": "vitest run --config vitest.config.unit.ts",
    "test:ci": "vitest run --config vitest.config.ci.ts --coverage",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@blindpass/api-schema": "workspace:*",
    "@blindpass/crypto": "workspace:*",
    "@blindpass/types": "workspace:*",
    "@blindpass/vault": "workspace:*",
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "uuidv7": "^1.2.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  }
}
