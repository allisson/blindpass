# ─────────────────────────────────────────────────────────────────────────────
# BlindPass — Environment Variables
# Copy this file to .env and fill in the required values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection URL.
# Change the password before deploying to any non-local environment.
DATABASE_URL=postgres://postgres:blindpass@db:5432/blindpass

# ── Security ──────────────────────────────────────────────────────────────────
# Required. Base64-encoded 32-byte key used to encrypt stored authenticator secrets.
# Generate one with:
# openssl rand -base64 32
TOTP_SECRET_ENCRYPTION_KEY=

# ── Session store ─────────────────────────────────────────────────────────────
# Required in production. Redis URL for server-side session storage.
REDIS_URL=redis://redis:6379

# ── Server ────────────────────────────────────────────────────────────────────
# Required in production. Public URL of the web app (used for CORS).
CORS_ORIGIN=https://yourdomain.com

# Optional. Set when the web app and API run on different subdomains
# under the same domain (e.g. app.example.com + api.example.com).
COOKIE_DOMAIN=yourdomain.com

# Optional. Defaults shown.
# PORT=3000
# LOG_LEVEL=info
